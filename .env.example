# ==========================================================
# SOLCARE / GROWATT - VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais.
# Nunca envie o arquivo .env para o GitHub.
# ==========================================================

# --------------------------
# Growatt OpenAPI
# --------------------------
GROWATT_API_TOKEN=
GROWATT_SERVER_URL=https://openapi.growatt.com/v1/

# Opcionais: se vazios, o sistema tenta localizar automaticamente
GROWATT_PLANT_ID=
GROWATT_DEVICE_SN=

# --------------------------
# Supabase / PostgreSQL
# --------------------------
DATABASE_URL=

# --------------------------
# WhatsApp - CallMeBot
# --------------------------
WHATSAPP_PHONE=
WHATSAPP_APIKEY=

# Segundo destinatário (opcional)
WHATSAPP_PHONE_2=
WHATSAPP_APIKEY_2=

# --------------------------
# Localização da usina
# --------------------------
STATION_LATITUDE=-14.2732856
STATION_LONGITUDE=-42.2586032

# --------------------------
# Relatório mensal e economia
# --------------------------
ENERGY_TARIFF=
AVERAGE_CONSUMPTION_KWH=
TUSD_FIO_B_KWH=
FIO_B_PERCENTAGE=

# Opcional para gerar um mês específico no formato YYYY-MM
REPORT_YEAR_MONTH=

# --------------------------
# Análise preventiva de manutenção
# Os valores abaixo são opcionais; estes são os padrões sugeridos.
# --------------------------
MAINTENANCE_HISTORY_DAYS=45
MAINTENANCE_RECENT_DAYS=3
MAINTENANCE_BASELINE_DAYS=7
MAINTENANCE_DROP_PERCENT=25
MAINTENANCE_MIN_RADIATION_WH_M2=3000
